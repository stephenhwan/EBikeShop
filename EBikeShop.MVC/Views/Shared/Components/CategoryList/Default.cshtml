@model List<EBikeShop.MVC.ViewModels.CategoryVM>


<h1>Category List</h1>

<table class="table">
    <thead>
        <tr>
            <th>No.</th>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Position</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="Edit" class="btn btn-primary" asp-route-id="@item.Id">Edit</a> |
                    <button type="button" class="btn btn-info" onclick="getCategoryDetail('@item.Id');">Details</button> |
                    <button class="btn btn-danger" onclick="openDeleteModal('@item.Id');">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>
