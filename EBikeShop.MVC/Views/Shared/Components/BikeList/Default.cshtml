@model List<EBikeShop.MVC.ViewModels.BikeVM>

<h1>Bike List</h1>

<table class="table">
    <thead>
        <tr>
            <th>Position</th>
            <th>Name</th>
            <th>Description</th>
            <th>Year</th>
            <th>BrandName</th>
            <th>CategoryName</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Position</td>
                <td>
                    @item.Name
                    @* @Html.DisplayFor(modelItem => item.Name) *@
                </td>
                <td>@item.Description</td>
                @* <td>@item.Year</td> *@
                <td>
                    <div>@item.Year</div>
                </td>
				<td>@item.BrandName</td>    
                <td>@item.CategoryName</td>
                <td>
                    <a asp-action="Edit" class="btn btn-primary" asp-route-id="@item.Id">Edit</a> |
                    <button type="button" class="btn btn-info" onclick="getBikeDetail('@item.Id');">
                        Details
                    </button>
                    @* <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#eBikeModal">
                        Details
                    </button> *@
                    @* <a asp-action="Details" class="btn btn-info" asp-route-id="@item.Id">Details</a> | *@
                    | <a asp-action="Delete" class="btn btn-danger" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>